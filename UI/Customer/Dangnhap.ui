  <property name="styleSheet">
   <string notr="true">
QWidget#centralwidget {
    background-color: #E8F6FD;
}
QFrame#card {
    background-color: #FFFFFF;
    border-radius: 20px;
    border: 1.5px solid #B3E0F5;
}
QLabel#lbl_title {
    color: #0A4D7A;
    font-size: 22px;
    font-weight: 700;
}
QLabel#lbl_subtitle {
    color: #3A9EC9;
    font-size: 13px;
}
QLabel#lbl_field_user,
QLabel#lbl_field_pass {
    color: #0D6FA6;
    font-size: 13px;
    font-weight: 600;
}
QLineEdit#inp_username,
QLineEdit#inp_password {
    background-color: #F0FAFF;
    border: 1.5px solid #B3E0F5;
    border-radius: 12px;
    padding: 11px 14px;
    font-size: 14px;
    color: #0A3D5C;
    selection-background-color: #29B6F6;
}
QLineEdit#inp_username:hover,
QLineEdit#inp_password:hover {
    border-color: #29B6F6;
    background-color: #E8F6FD;
}
QLineEdit#inp_username:focus,
QLineEdit#inp_password:focus {
    border-color: #0288D1;
    background-color: #FFFFFF;
}
QPushButton#btn_eye {
    background: transparent;
    border: none;
    color: #4FC3F7;
    font-size: 16px;
    padding: 0px;
}
QPushButton#btn_eye:hover {
    color: #0288D1;
}
QPushButton#btn_login {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
        stop:0 #0288D1, stop:1 #29B6F6);
    color: #FFFFFF;
    border: none;
    border-radius: 14px;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 0px;
}
QPushButton#btn_login:hover {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
        stop:0 #039BE5, stop:1 #4FC3F7);
}
QPushButton#btn_login:pressed {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
        stop:0 #0277BD, stop:1 #0288D1);
}
QPushButton#btn_login:disabled {
    background: #B3E0F5;
    color: #FFFFFF;
}
QPushButton#btn_register,
QPushButton#btn_forgot {
    background: transparent;
    border: none;
    color: #0288D1;
    font-size: 13px;
    font-weight: 600;
    text-decoration: underline;
    padding: 0px;
}
QPushButton#btn_register:hover,
QPushButton#btn_forgot:hover {
    color: #01579B;
}
QFrame#banner {
    background-color: #E1F5FE;
    border-radius: 12px;
    border: 1px solid #B3E0F5;
}
QLabel#lbl_banner {
    color: #0D6FA6;
    font-size: 12px;
}
QLabel#lbl_divider {
    color: #81D4FA;
    font-size: 12px;
}
QFrame#line_left,
QFrame#line_right {
    color: #B3E0F5;
}
QLabel#lbl_no_account {
    color: #3A9EC9;
    font-size: 13px;
}
   </string>
