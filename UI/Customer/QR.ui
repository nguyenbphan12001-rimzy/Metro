  <property name="styleSheet">
   <string notr="true">
/* ===== GLOBAL ===== */
QWidget#QRPaymentDialog {
    background-color: #E8F6FD;
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;, sans-serif;
}

/* ===== MAIN CARD ===== */
QFrame#mainCard {
    background-color: #FFFFFF;
    border: 1.5px solid #B3E0F5;
    border-radius: 20px;
}

/* ===== SUCCESS ICON CIRCLE ===== */
QLabel#iconCircle {
    background-color: qradialgradient(
        cx:0.5, cy:0.5, radius:0.5,
        fx:0.5, fy:0.5,
        stop:0 #FFFFFF,
        stop:1 #C8EFFD
    );
    border: 2.5px solid #29B6F6;
    border-radius: 28px;
    color: #0A7EC2;
    font-size: 24px;
    font-weight: bold;
    qproperty-alignment: AlignCenter;
}

/* ===== TITLE ===== */
QLabel#titleLabel {
    color: #0A4D7A;
    font-size: 20px;
    font-weight: 700;
    qproperty-alignment: AlignCenter;
}

/* ===== TICKET CODE ===== */
QLabel#ticketCodeLabel {
    color: #3A9EC9;
    font-size: 13px;
    font-weight: 500;
    qproperty-alignment: AlignCenter;
}

/* ===== QR FRAME ===== */
QFrame#qrFrame {
    background-color: #FFFFFF;
    border: 1.5px solid #B3E0F5;
    border-radius: 16px;
}

/* ===== QR LABEL ===== */
QLabel#qrLabel {
    background-color: #FFFFFF;
    border: none;
    qproperty-alignment: AlignHCenter | AlignVCenter;
}

/* ===== QR HINT ===== */
QLabel#qrHintLabel {
    color: #3A9EC9;
    font-size: 12px;
    qproperty-alignment: AlignCenter;
}

/* ===== INFO BANNER ===== */
QFrame#infoBanner {
    background-color: #E1F5FE;
    border: 1.5px solid #B3E0F5;
    border-radius: 14px;
}

/* ===== INFO ROW LABELS ===== */
QLabel#infoKeyLabel {
    color: #0288D1;
    font-size: 13px;
    font-weight: 500;
}

QLabel#infoValueLabel {
    color: #0A4D7A;
    font-size: 13px;
    font-weight: 600;
    qproperty-alignment: AlignRight | AlignVCenter;
}

/* ===== STATUS BADGE ===== */
QLabel#statusBadge {
    background-color: #E8F6FD;
    border: 1px solid #B3E0F5;
    border-radius: 10px;
    color: #0288D1;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 12px;
    qproperty-alignment: AlignCenter;
}

/* ===== DIVIDER ===== */
QFrame#dividerLine {
    background-color: #B3E0F5;
    border: none;
    max-height: 1px;
}

/* ===== SECONDARY BUTTONS ===== */
QPushButton#btnDownload,
QPushButton#btnShare {
    background-color: #FFFFFF;
    border: 1.5px solid #B3E0F5;
    border-radius: 12px;
    color: #0288D1;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 0px;
}

QPushButton#btnDownload:hover,
QPushButton#btnShare:hover {
    background-color: #E8F6FD;
    border-color: #29B6F6;
    color: #0A4D7A;
}

QPushButton#btnDownload:pressed,
QPushButton#btnShare:pressed {
    background-color: #B3E0F5;
}

/* ===== PRIMARY BUTTON ===== */
QPushButton#btnHome {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #00C6FB,
        stop:0.5 #0288D1,
        stop:1 #005B9F
    );
    border: none;
    border-radius: 14px;
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 700;
    padding: 14px 0px;
}

QPushButton#btnHome:hover {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #40D4FF,
        stop:0.5 #039BE5,
        stop:1 #0277BD
    );
}

QPushButton#btnHome:pressed {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #0288D1,
        stop:0.5 #0277BD,
        stop:1 #01579B
    );
}
