  <property name="styleSheet">
   <string notr="true">
/* ── Nền tổng ── */
QWidget#centralwidget {
    background-color: #E8F6FD;
}

/* ── Header ── */
QFrame#header {
    background-color: #FFFFFF;
    border-bottom: 1px solid #B3E0F5;
}
QLabel#lbl_avatar {
    background-color: #29B6F6;
    border-radius: 22px;
    color: #FFFFFF;
    font-size: 15px;
    font-weight: 700;
}
QLabel#lbl_name {
    color: #0A4D7A;
    font-size: 15px;
    font-weight: 700;
}
QLabel#lbl_email {
    color: #3A9EC9;
    font-size: 12px;
}
QPushButton#btn_logout {
    background-color: #FFFFFF;
    border: 1.5px solid #B3E0F5;
    border-radius: 10px;
    color: #0288D1;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 14px;
}
QPushButton#btn_logout:hover {
    background-color: #E1F5FE;
    border-color: #29B6F6;
}
QPushButton#btn_logout:pressed {
    background-color: #B3E0F5;
}

/* ── Wallet card ── */
QFrame#wallet_card {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
        stop:0 #0288D1, stop:0.5 #29B6F6, stop:1 #4FC3F7);
    border-radius: 18px;
    border: none;
}
QLabel#lbl_wallet_title {
    color: #E1F5FE;
    font-size: 13px;
    font-weight: 500;
}
QLabel#lbl_balance {
    color: #FFFFFF;
    font-size: 30px;
    font-weight: 700;
}
QPushButton#btn_topup {
    background-color: rgba(255,255,255,0.22);
    border: 1.5px solid rgba(255,255,255,0.55);
    border-radius: 10px;
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 600;
    padding: 9px 0px;
}
QPushButton#btn_topup:hover {
    background-color: rgba(255,255,255,0.35);
}
QPushButton#btn_topup:pressed {
    background-color: rgba(255,255,255,0.15);
}
QPushButton#btn_history {
    background-color: rgba(255,255,255,0.12);
    border: 1.5px solid rgba(255,255,255,0.40);
    border-radius: 10px;
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 600;
    padding: 9px 0px;
}
QPushButton#btn_history:hover {
    background-color: rgba(255,255,255,0.25);
}
QPushButton#btn_history:pressed {
    background-color: rgba(255,255,255,0.08);
}

/* ── Menu cards ── */
QFrame#card_buy,
QFrame#card_myticket {
    background-color: #FFFFFF;
    border-radius: 16px;
    border: 1.5px solid #B3E0F5;
}
QFrame#card_buy:hover,
QFrame#card_myticket:hover {
    border-color: #29B6F6;
    background-color: #F0FAFF;
}
QLabel#lbl_icon_buy,
QLabel#lbl_icon_ticket {
    background-color: #E1F5FE;
    border-radius: 12px;
    font-size: 22px;
}
QLabel#lbl_menu_title {
    color: #0A4D7A;
    font-size: 15px;
    font-weight: 700;
}
QLabel#lbl_menu_sub {
    color: #3A9EC9;
    font-size: 12px;
}
QPushButton#btn_buy,
QPushButton#btn_myticket {
    background-color: transparent;
    border: none;
    text-align: left;
}

/* ── Tip banner ── */
QFrame#tip_banner {
    background-color: #E1F5FE;
    border-radius: 14px;
    border: 1px solid #B3E0F5;
}
QLabel#lbl_tip_icon {
    font-size: 18px;
}
QLabel#lbl_tip_title {
    color: #0288D1;
    font-size: 13px;
    font-weight: 700;
}
QLabel#lbl_tip_body {
    color: #0D6FA6;
    font-size: 12px;
}
