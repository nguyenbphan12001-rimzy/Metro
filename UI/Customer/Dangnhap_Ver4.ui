<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>LoginWindow</class>
 <widget class="QMainWindow" name="LoginWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>460</width><height>700</height></rect>
  </property>
  <property name="minimumSize">
   <size><width>420</width><height>620</height></size>
  </property>
  <property name="windowTitle">
   <string>Metro Ticket System</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* ── Nền tổng: gradient xanh đậm theo chiều dọc ── */
QWidget#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:0.3, y2:1,
        stop:0 #0D1F3C,
        stop:0.4 #0A3060,
        stop:0.7 #0D4080,
        stop:1   #1A5FA8);
}

/* ── Card login nổi lên ── */
QFrame#card {
    background-color: rgba(255, 255, 255, 0.97);
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.15);
}

/* ── Logo: khung ngoài tạo hiệu ứng 3D ── */
QFrame#logo_outer {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #1E90FF, stop:0.5 #0060D0, stop:1 #003A8C);
    border-radius: 24px;
    border-top: 2px solid rgba(255,255,255,0.28);
    border-left: 1px solid rgba(255,255,255,0.12);
    border-right: 1px solid rgba(0,0,0,0.25);
    border-bottom: 2px solid rgba(0,0,0,0.35);
}
QFrame#logo_inner {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #2AA0FF, stop:1 #0070E0);
    border-radius: 16px;
    border-top: 1px solid rgba(255,255,255,0.2);
    border-bottom: 1px solid rgba(0,0,0,0.3);
}
QLabel#lbl_logo_icon {
    color: #E0F2FE;
    font-size: 28px;
}

/* ── Tiêu đề ── */
QLabel#lbl_title {
    color: #FFFFFF;
    font-size: 22px;
    font-weight: 700;
}
QLabel#lbl_subtitle {
    color: rgba(148, 213, 252, 0.85);
    font-size: 12px;
    letter-spacing: 1px;
}

/* ── Label field ── */
QLabel#lbl_field_user,
QLabel#lbl_field_pass {
    color: #0369A1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
}

/* ── Input fields ── */
QLineEdit#inp_username,
QLineEdit#inp_password {
    background-color: #F0F9FF;
    border: 1.5px solid #BAE6FD;
    border-radius: 12px;
    padding: 11px 14px;
    font-size: 14px;
    color: #0C4A6E;
    selection-background-color: #29B6F6;
}
QLineEdit#inp_username:hover,
QLineEdit#inp_password:hover {
    border-color: #38BDF8;
    background-color: #E8F6FD;
}
QLineEdit#inp_username:focus,
QLineEdit#inp_password:focus {
    border-color: #0284C7;
    background-color: #FFFFFF;
}

/* ── Eye button ── */
QPushButton#btn_eye {
    background: transparent;
    border: none;
    color: #38BDF8;
    font-size: 16px;
    padding: 0px;
}
QPushButton#btn_eye:hover { color: #0284C7; }

/* ── Nút đăng nhập gradient 3D ── */
QPushButton#btn_login {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #0284C7, stop:0.5 #0EA5E9, stop:1 #38BDF8);
    color: #FFFFFF;
    border: none;
    border-radius: 14px;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 0px;
    border-top: 1px solid rgba(255,255,255,0.2);
}
QPushButton#btn_login:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #0369A1, stop:0.5 #0284C7, stop:1 #0EA5E9);
}
QPushButton#btn_login:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #075985, stop:1 #0284C7);
    border-top: 1px solid rgba(0,0,0,0.15);
}
QPushButton#btn_login:disabled {
    background: #BAE6FD;
    color: rgba(255,255,255,0.6);
}

/* ── Link buttons ── */
QPushButton#btn_register,
QPushButton#btn_forgot {
    background: transparent;
    border: none;
    color: #0284C7;
    font-size: 13px;
    font-weight: 600;
    text-decoration: underline;
    padding: 0px;
}
QPushButton#btn_register:hover,
QPushButton#btn_forgot:hover { color: #075985; }

/* ── Divider ── */
QLabel#lbl_divider { color: #7DD3FC; font-size: 12px; }
QFrame#line_left, QFrame#line_right { color: #BAE6FD; }
QLabel#lbl_no_account { color: #64748B; font-size: 13px; }

/* ── Footer pills ── */
QFrame#pill_1, QFrame#pill_2 {
    background-color: rgba(255, 255, 255, 0.09);
    border: 1px solid rgba(148, 213, 252, 0.22);
    border-radius: 16px;
}
QLabel#lbl_pill_1, QLabel#lbl_pill_2 {
    color: rgba(186, 230, 253, 0.8);
    font-size: 11px;
}
QLabel#lbl_pill_dot_1, QLabel#lbl_pill_dot_2 {
    color: #38BDF8;
    font-size: 18px;
    padding-bottom: 4px;
}
   </string>
  </property>

