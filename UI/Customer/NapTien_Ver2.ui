   </size>
  </property>
  <property name="windowTitle">
   <string>Metro Ticket System – Nạp tiền</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* ── Nền tổng: gradient xanh đậm (đồng bộ Login/Dashboard) ── */
QWidget#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:0.3, y2:1,
        stop:0 #0D1F3C,
        stop:0.4 #0A3060,
        stop:0.7 #0D4080,
        stop:1   #1A5FA8);
}

/* ── Header row ── */
QPushButton#btn_back {
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 10px;
    color: #E0F2FE;
    font-size: 14px;
    font-weight: 600;
    padding: 6px 14px;
}
QPushButton#btn_back:hover { background: rgba(255,255,255,0.18); }

QLabel#lbl_header_title {
    color: #FFFFFF;
    font-size: 17px;
    font-weight: 700;
}

/* ── Card số dư hiện tại (gradient xanh, giống dashboard) ── */
QFrame#balance_card {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #0EA5E9, stop:0.5 #0284C7, stop:1 #075985);
    border-radius: 20px;
    border-top: 1px solid rgba(255,255,255,0.25);
}
QLabel#lbl_balance_caption {
    color: rgba(255,255,255,0.85);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
}
QLabel#lbl_balance_value {
    color: #FFFFFF;
    font-size: 30px;
    font-weight: 800;
}

/* ── Card trắng chứa form nạp tiền ── */
QFrame#form_card {
    background-color: rgba(255, 255, 255, 0.97);
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.15);
}

QLabel#lbl_field_amount,
QLabel#lbl_field_quick,
QLabel#lbl_field_method {
    color: #0369A1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
}

/* ── Ô nhập số tiền ── */
QLineEdit#inp_amount {
    background-color: #F0F9FF;
    border: 1.5px solid #BAE6FD;
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 18px;
    font-weight: 700;
    color: #0C4A6E;
    selection-background-color: #29B6F6;
}
QLineEdit#inp_amount:hover { border-color: #38BDF8; background-color: #E8F6FD; }
QLineEdit#inp_amount:focus { border-color: #0284C7; background-color: #FFFFFF; }

/* ── Quick amount chips ── */
QPushButton#btn_quick_1, QPushButton#btn_quick_2,
QPushButton#btn_quick_3, QPushButton#btn_quick_4 {
    background-color: #F0F9FF;
    border: 1.5px solid #BAE6FD;
    border-radius: 12px;
    color: #0369A1;
    font-size: 13px;
    font-weight: 700;
    padding: 10px 0px;
}
QPushButton#btn_quick_1:hover, QPushButton#btn_quick_2:hover,
QPushButton#btn_quick_3:hover, QPushButton#btn_quick_4:hover {
    border-color: #38BDF8; background-color: #E8F6FD;
}
QPushButton#btn_quick_1:checked, QPushButton#btn_quick_2:checked,
QPushButton#btn_quick_3:checked, QPushButton#btn_quick_4:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #0284C7, stop:1 #38BDF8);
    color: #FFFFFF;
    border: none;
}

/* ── Dropdown phương thức thanh toán ── */
QComboBox#cbo_payment_method {
    background-color: #F0F9FF;
    border: 1.5px solid #BAE6FD;
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 14px;
    color: #0C4A6E;
}
QComboBox#cbo_payment_method:hover { border-color: #38BDF8; }
QComboBox#cbo_payment_method::drop-down { border: none; width: 28px; }
QComboBox#cbo_payment_method QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #BAE6FD;
    border-radius: 8px;
    selection-background-color: #BAE6FD;
    color: #0C4A6E;
    padding: 4px;
}

/* ── Nút xác nhận nạp tiền (gradient, giống btn_login) ── */
QPushButton#btn_confirm_topup {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #0284C7, stop:0.5 #0EA5E9, stop:1 #38BDF8);
    color: #FFFFFF;
    border: none;
    border-radius: 14px;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 0px;
    border-top: 1px solid rgba(255,255,255,0.2);
}
QPushButton#btn_confirm_topup:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #0369A1, stop:0.5 #0284C7, stop:1 #0EA5E9);
}
QPushButton#btn_confirm_topup:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #075985, stop:1 #0284C7);
}
QPushButton#btn_confirm_topup:disabled {
    background: #BAE6FD;
    color: rgba(255,255,255,0.6);
}

QLabel#lbl_note {
    color: #64748B;
    font-size: 11px;
}
   </string>
