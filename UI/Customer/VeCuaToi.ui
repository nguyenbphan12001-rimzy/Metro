   <string notr="true">
/* ── Nền tổng ── */
QWidget#centralwidget {
    background-color: #F0F9FF;
}

/* ── Header ── */
QFrame#header {
    background-color: #FFFFFF;
    border-bottom: 1px solid #BAE6FD;
}
QLabel#lbl_title {
    color: #0C4A6E;
    font-size: 16px;
    font-weight: 700;
    font-family: 'Segoe UI', system-ui, sans-serif;
}
QPushButton#btn_back {
    background-color: transparent;
    border: none;
    color: #0284C7;
    font-size: 20px;
    font-weight: bold;
}
QPushButton#btn_back:hover {
    color: #0EA5E9;
}

/* ── Filter tab bar ── */
QFrame#filterBar {
    background-color: #FFFFFF;
    border-radius: 12px;
    border: 1px solid #E0F2FE;
}
QPushButton#btnTabAll,
QPushButton#btnTabUnused,
QPushButton#btnTabUsed,
QPushButton#btnTabExpired {
    border: none;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 10px;
    background-color: transparent;
    color: #7DD3FC;
}
QPushButton#btnTabAll:hover,
QPushButton#btnTabUnused:hover,
QPushButton#btnTabUsed:hover,
QPushButton#btnTabExpired:hover {
    background-color: #F0F9FF;
    color: #0284C7;
}

/* ── Scroll area ── */
QScrollArea {
    background: transparent;
    border: none;
}
QScrollBar:vertical {
    width: 5px;
    background: #E0F2FE;
    border-radius: 3px;
}
QScrollBar::handle:vertical {
    background: #7DD3FC;
    border-radius: 3px;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

/* ── Empty state ── */
QLabel#lbl_empty {
    color: #93C5FD;
    font-size: 13px;
    font-family: 'Segoe UI', system-ui, sans-serif;
}
