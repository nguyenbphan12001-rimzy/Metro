 <class>ForgotPasswordWindow</class>
 <widget class="QMainWindow" name="ForgotPasswordWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>460</width><height>680</height></rect>
  </property>
  <property name="minimumSize">
   <size><width>440</width><height>660</height></size>
  </property>
  <property name="windowTitle">
   <string>Metro Ticket System – Khôi phục mật khẩu</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
QWidget#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:0.3, y2:1,
        stop:0 #0D1F3C, stop:0.4 #0A3060,
        stop:0.7 #0D4080, stop:1 #1A5FA8);
}
QFrame#form_card {
    background-color: rgba(255,255,255,0.97);
    border-radius: 22px;
    border: 1px solid rgba(255,255,255,0.15);
    border-bottom: 4px solid rgba(0,40,100,0.28);
}
QFrame#icon_outer {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
        stop:0 #1E90FF, stop:0.5 #0060D0, stop:1 #003A8C);
    border-radius: 20px;
    border-top: 2px solid rgba(255,255,255,0.28);
    border-left: 1px solid rgba(255,255,255,0.12);
    border-right: 1px solid rgba(0,0,0,0.25);
    border-bottom: 2px solid rgba(0,0,0,0.35);
}
QFrame#icon_inner {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
        stop:0 #2AA0FF, stop:1 #0070E0);
    border-radius: 13px;
    border-top: 1px solid rgba(255,255,255,0.20);
    border-bottom: 1px solid rgba(0,0,0,0.30);
}
QLabel#lbl_icon_key { color:#E0F2FE; font-size:22px; }
QLabel#lbl_title { color:#FFFFFF; font-size:21px; font-weight:700; }
QLabel#lbl_subtitle { color:rgba(148,213,252,0.85); font-size:11px; letter-spacing:1.2px; }
QFrame#step_dot_1 {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:1,stop:0 #38BDF8,stop:1 #0284C7);
    border-radius: 11px;
    border: 2px solid rgba(255,255,255,0.35);
}
QFrame#step_dot_2 {
    background: rgba(255,255,255,0.15);
    border-radius: 11px;
    border: 2px solid rgba(148,213,252,0.35);
}
QLabel#lbl_step_num_1 { color:#FFFFFF; font-size:11px; font-weight:700; }
QLabel#lbl_step_num_2 { color:rgba(148,213,252,0.60); font-size:11px; font-weight:600; }
QFrame#step_line { background:rgba(148,213,252,0.30); max-height:2px; min-height:2px; }
QLabel#lbl_step_label_1 { color:#7DD3FC; font-size:10px; font-weight:600; }
QLabel#lbl_step_label_2 { color:rgba(148,213,252,0.45); font-size:10px; }
QLabel#lbl_field_user, QLabel#lbl_field_phone, QLabel#lbl_field_newpass {
    color:#0369A1; font-size:11px; font-weight:700; letter-spacing:0.8px;
}
QLineEdit#txt_username, QLineEdit#txt_phone, QLineEdit#txt_new_pass {
    background-color:#F0F9FF; border:1.5px solid #BAE6FD;
    border-radius:12px; padding:10px 14px;
    font-size:13px; color:#0C4A6E;
}
QLineEdit#txt_username:hover, QLineEdit#txt_phone:hover, QLineEdit#txt_new_pass:hover {
    border-color:#38BDF8; background-color:#E8F6FD;
}
QLineEdit#txt_username:focus, QLineEdit#txt_phone:focus, QLineEdit#txt_new_pass:focus {
    border-color:#0284C7; background-color:#FFFFFF;
}
QLineEdit#txt_username:disabled, QLineEdit#txt_phone:disabled {
    background-color:#EFF6FB; color:#94A8B8; border-color:#DCEEF8;
}
QPushButton#btn_action {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
        stop:0 #0284C7, stop:0.5 #0EA5E9, stop:1 #38BDF8);
    color:#FFFFFF; border:none; border-radius:13px;
    font-size:14px; font-weight:700;
    border-top:1px solid rgba(255,255,255,0.20);
}
QPushButton#btn_action:hover {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
        stop:0 #0369A1, stop:0.5 #0284C7, stop:1 #0EA5E9);
}
QPushButton#btn_action:pressed {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
        stop:0 #075985, stop:1 #0284C7);
}
QFrame#hint_banner {
    background:rgba(255,255,255,0.07);
    border-radius:12px;
    border:1px solid rgba(148,213,252,0.20);
    border-left:3px solid rgba(56,189,248,0.65);
}
QLabel#lbl_hint_icon { font-size:13px; }
QLabel#lbl_hint_text { color:rgba(186,230,253,0.78); font-size:11px; }
QFrame#pill_secure, QFrame#pill_support {
    background-color:rgba(255,255,255,0.09);
    border:1px solid rgba(148,213,252,0.22);
    border-radius:14px;
}
QLabel#lbl_pill_dot_s, QLabel#lbl_pill_dot_sp { color:#38BDF8; font-size:13px; }
QLabel#lbl_pill_secure, QLabel#lbl_pill_support { color:rgba(186,230,253,0.80); font-size:11px; }
QPushButton#btn_back {
    background:transparent; border:none;
    color:rgba(125,211,252,0.80); font-size:13px; font-weight:600;
}
QPushButton#btn_back:hover { color:#FFFFFF; }
   </string>
