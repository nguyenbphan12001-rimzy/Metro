<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>RefundWindow</class>
 <widget class="QMainWindow" name="RefundWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>460</width><height>750</height></rect>
  </property>
  <property name="minimumSize">
   <size><width>420</width><height>680</height></size>
  </property>
  <property name="windowTitle">
   <string>Metro Ticket System – Hoàn vé</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* ── Nền tổng: đồng bộ với NapTien / Dashboard ── */
QWidget#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:0.3, y2:1,
        stop:0 #0D1F3C,
        stop:0.4 #0A3060,
        stop:0.7 #0D4080,
        stop:1   #1A5FA8);
}

/* ── Header ── */
QPushButton#btn_back {
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 10px;
    color: #E0F2FE;
    font-size: 14px;
    font-weight: 600;
    padding: 6px 14px;
}
QPushButton#btn_back:hover { background: rgba(255,255,255,0.18); }

QLabel#lbl_header_title {
    color: #FFFFFF;
    font-size: 17px;
    font-weight: 700;
}

/* ── Card số dư (đồng bộ dashboard) ── */
QFrame#balance_card {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #0EA5E9, stop:0.5 #0284C7, stop:1 #075985);
    border-radius: 20px;
    border-top: 1px solid rgba(255,255,255,0.25);
}
QLabel#lbl_balance_caption {
    color: rgba(255,255,255,0.85);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
}
QLabel#lbl_balance_value {
    color: #FFFFFF;
    font-size: 30px;
    font-weight: 800;
}

/* ── Card trắng chứa nội dung ── */
QFrame#refund_card {
    background-color: rgba(255, 255, 255, 0.97);
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.15);
}

/* ── Label nhãn field ── */
QLabel#lbl_field_ticket,
QLabel#lbl_field_info {
    color: #0369A1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
}

/* ── Ô nhập mã vé ── */
QLineEdit#inp_ticket_code {
    background-color: #F0F9FF;
    border: 1.5px solid #BAE6FD;
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 15px;
    font-weight: 600;
    color: #0C4A6E;
    selection-background-color: #29B6F6;
}
QLineEdit#inp_ticket_code:hover { border-color: #38BDF8; background-color: #E8F6FD; }
QLineEdit#inp_ticket_code:focus { border-color: #0284C7; background-color: #FFFFFF; }

/* ── Nút tra cứu ── */
QPushButton#btn_lookup {
    background: rgba(14,165,233,0.12);
    border: 1.5px solid #BAE6FD;
    border-radius: 12px;
    color: #0284C7;
    font-size: 13px;
    font-weight: 700;
    padding: 12px 0px;
}
QPushButton#btn_lookup:hover {
    background: rgba(14,165,233,0.22);
    border-color: #0EA5E9;
}

/* ── Card thông tin vé (hiện ra sau khi tra cứu) ── */
QFrame#ticket_info_card {
    background-color: #F0F9FF;
    border: 1.5px solid #BAE6FD;
    border-radius: 14px;
}
QLabel#lbl_ticket_route {
    color: #0C4A6E;
    font-size: 14px;
    font-weight: 700;
}
QLabel#lbl_ticket_type {
    color: #0284C7;
    font-size: 12px;
    font-weight: 600;
}
QLabel#lbl_ticket_date {
    color: #64748B;
    font-size: 11px;
}
QLabel#lbl_ticket_price_caption {
    color: #64748B;
    font-size: 11px;
}
QLabel#lbl_ticket_price_value {
    color: #0EA5E9;
    font-size: 20px;
    font-weight: 800;
}

/* ── Badge trạng thái vé ── */
QLabel#badge_status {
    background-color: #DCFCE7;
    color: #166534;
    border-radius: 8px;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
}

/* ── Divider ── */
QFrame#divider {
    color: #E0F2FE;
}

/* ── Số tiền hoàn (hiển thị nổi bật) ── */
QFrame#refund_amount_row {
    background-color: #FFF7ED;
    border: 1.5px solid #FED7AA;
    border-radius: 12px;
}
QLabel#lbl_refund_caption {
    color: #9A3412;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.6px;
}
QLabel#lbl_refund_amount {
    color: #EA580C;
    font-size: 22px;
    font-weight: 800;
}
QLabel#lbl_refund_note {
    color: #C2410C;
    font-size: 11px;
}

/* ── Nút xác nhận hoàn vé ── */
QPushButton#btn_confirm_refund {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #0284C7, stop:0.5 #0EA5E9, stop:1 #38BDF8);
    color: #FFFFFF;
    border: none;
    border-radius: 14px;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 0px;
    border-top: 1px solid rgba(255,255,255,0.2);
}
QPushButton#btn_confirm_refund:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #0369A1, stop:0.5 #0284C7, stop:1 #0EA5E9);
}
QPushButton#btn_confirm_refund:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #075985, stop:1 #0284C7);
}
QPushButton#btn_confirm_refund:disabled {
    background: #BAE6FD;
    color: rgba(255,255,255,0.6);
}

QLabel#lbl_bottom_note {
    color: rgba(255,255,255,0.55);
    font-size: 11px;
}
   </string>
