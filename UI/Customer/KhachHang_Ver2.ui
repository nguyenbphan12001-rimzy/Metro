/* ══════════════════════════════════════════════
   BASE — nền gradient nhẹ để tạo chiều sâu tổng thể
   ══════════════════════════════════════════════ */
QWidget#centralwidget {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #D6EEF8,
        stop:0.45 #E8F6FD,
        stop:1 #F0FAFE
    );
}

/* ══════════════════════════════════════════════
   HEADER — nổi lên với shadow dưới
   ══════════════════════════════════════════════ */
QFrame#header {
    background-color: #FFFFFF;
    border-bottom: 1px solid #C5E8F7;
    /* shadow giả bằng bottom border dày hơn */
    border-bottom: 2px solid #B3DDF0;
}

/* Avatar — ring effect bằng double border */
QLabel#lbl_avatar {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
        stop:0 #29B6F6, stop:1 #0277BD);
    border-radius: 22px;
    color: #FFFFFF;
    font-size: 15px;
    font-weight: 800;
    border: 2px solid #81D4FA;
}

QLabel#lbl_name {
    color: #0A3D6B;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.2px;
}

QLabel#lbl_email {
    color: #4BADD6;
    font-size: 11px;
    letter-spacing: 0.3px;
}

/* Logout button — ghost style với hover lift */
QPushButton#btn_logout {
    background-color: #FFFFFF;
    border: 1.5px solid #90CAE8;
    border-radius: 10px;
    color: #0277BD;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
}
QPushButton#btn_logout:hover {
    background-color: #E1F5FE;
    border-color: #0EA5E9;
    color: #0369A1;
}
QPushButton#btn_logout:pressed {
    background-color: #BAE6FD;
    border-color: #0284C7;
}

/* ══════════════════════════════════════════════
   WALLET CARD — flagship element, glassmorphism + depth
   ══════════════════════════════════════════════ */
QFrame#wallet_card {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0   #01579B,
        stop:0.3 #0277BD,
        stop:0.65 #0288D1,
        stop:1   #29B6F6
    );
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.25);
    /* Depth trick: inner highlight top + shadow bottom via border layering */
    border-top: 1.5px solid rgba(255,255,255,0.45);
    border-bottom: 3px solid rgba(0,60,120,0.35);
}

QLabel#lbl_wallet_title {
    color: rgba(225, 245, 254, 0.85);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.8px;
}

QLabel#lbl_balance {
    color: #FFFFFF;
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.5px;
}

/* Nạp tiền button — frosted glass effect */
QPushButton#btn_topup {
    background-color: rgba(255,255,255,0.18);
    border: 1.5px solid rgba(255,255,255,0.50);
    border-radius: 12px;
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 700;
    padding: 11px 0px;
    letter-spacing: 0.3px;
}
QPushButton#btn_topup:hover {
    background-color: rgba(255,255,255,0.32);
    border-color: rgba(255,255,255,0.80);
}
QPushButton#btn_topup:pressed {
    background-color: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.35);
}

/* Hoàn vé button — viền nhạt hơn để phân vai phụ so với nút Nạp tiền chính */
QPushButton#btn_refund {
    background-color: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.30);
    border-radius: 12px;
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 700;
    padding: 11px 0px;
    letter-spacing: 0.3px;
}
QPushButton#btn_refund:hover {
    background-color: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.55);
}
QPushButton#btn_refund:pressed {
    background-color: rgba(255,255,255,0.10);
}

/* ══════════════════════════════════════════════
   MENU CARDS — nổi 3D với shadow + hover lift
   ══════════════════════════════════════════════ */
QFrame#card_buy,
QFrame#card_myticket {
    background-color: #FFFFFF;
    border-radius: 18px;
    /* Layered border để tạo elevation illusion */
    border: 1px solid #C8E9F5;
    border-bottom: 3px solid #A8D5EC;
    border-right: 2px solid #B8DFF0;
}
QFrame#card_buy:hover,
QFrame#card_myticket:hover {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,
        stop:0 #FFFFFF, stop:1 #F0FAFF);
    border-color: #29B6F6;
    border-bottom: 3px solid #0288D1;
    border-right: 2px solid #4FC3F7;
}

/* Icon bubble — gradient background cho depth */
QLabel#lbl_icon_buy {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
        stop:0 #E1F5FE, stop:1 #B3E5FC);
    border-radius: 14px;
    font-size: 24px;
    border: 1px solid #81D4FA;
}
QLabel#lbl_icon_ticket {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
        stop:0 #E8F5E9, stop:1 #C8E6C9);
    border-radius: 14px;
    font-size: 24px;
    border: 1px solid #A5D6A7;
}

QLabel#lbl_menu_title {
    color: #083F66;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.1px;
}
QLabel#lbl_menu_sub {
    color: #4A9FC0;
    font-size: 11.5px;
    line-height: 1.4;
}

/* ══════════════════════════════════════════════
   TIP BANNER — subtle card với accent border kép
   ══════════════════════════════════════════════ */
QFrame#tip_banner {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0,
        stop:0 #E1F5FE, stop:1 #EDF7FB);
    border-radius: 16px;
    border: 1px solid #B3E0F5;
    border-left: 4px solid #29B6F6;
}

QLabel#lbl_tip_icon {
    font-size: 20px;
}
QLabel#lbl_tip_title {
    color: #0277BD;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1px;
}
QLabel#lbl_tip_body {
    color: #1A6E9A;
    font-size: 11.5px;
    line-height: 1.5;
}

/* ══════════════════════════════════════════════
   SCROLL AREA — trong suốt, scrollbar mỏng
   ══════════════════════════════════════════════ */
QScrollArea {
    background: transparent;
    border: none;
}
QScrollBar:vertical {
    width: 5px;
    background: transparent;
    margin: 4px 0px;
}
QScrollBar::handle:vertical {
    background: #90CAE8;
    border-radius: 2px;
    min-height: 20px;
}
QScrollBar::handle:vertical:hover {
    background: #29B6F6;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}
   </string>
