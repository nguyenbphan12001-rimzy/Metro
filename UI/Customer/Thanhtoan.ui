 <class>MetroBookingForm</class>
 <widget class="QWidget" name="MetroBookingForm">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>436</width>
    <height>851</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Đặt Vé Metro</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* Định hình giao diện tổng thể theo thiết kế Sky Blue */
    QWidget#MetroBookingForm {
        background-color: #F0F9FF;
    }

    QLabel {
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    /* Giao diện Thẻ (Card) */
    QFrame#cardJourney, QFrame#cardSummary {
        background-color: #ffffff;
        border: 1px solid #E0F2FE;
        border-radius: 16px;
    }

    /* Tiêu đề Thẻ */
    QLabel#lblJourneyTitle {
        font-size: 15px;
        font-weight: bold;
        color: #0C4A6E;
    }

    /* Nhãn các trường nhập liệu */
    QLabel.form-label {
        font-size: 12px;
        color: #0284C7;
        font-weight: 600;
    }

    /* Hộp chọn Combo Box */
    QComboBox {
        padding: 8px 12px;
        border: 1px solid #BAE6FD;
        border-radius: 10px;
        font-size: 13px;
        color: #0C4A6E;
        background-color: #F0F9FF;
    }
    QComboBox::drop-down {
        border: none;
        subcontrol-origin: padding;
        subcontrol-position: top right;
        width: 25px;
    }

    /* Thẻ Loại Vé (Ticket Grid Item) */
    QFrame.ticket-card {
        border: 1.5px solid #E0F2FE;
        border-radius: 12px;
        background-color: #ffffff;
    }
    QFrame.ticket-card:hover {
        border-color: #7DD3FC;
        background-color: #F0F9FF;
    }
    /* Vé đang chọn mặc định */
    QFrame#frameTicket1 {
        border-color: #0EA5E9;
        background-color: #E0F2FE;
    }

    /* Nút Tăng/Giảm số lượng */
    QPushButton.qty-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #BAE6FD;
        background-color: #F0F9FF;
        color: #0284C7;
        font-size: 16px;
        font-weight: bold;
    }
    QPushButton.qty-btn:hover {
        background-color: #BAE6FD;
        border-color: #0EA5E9;
    }

    /* Ví tiền và Số dư */
    QFrame#balanceBox {
        background-color: #E0F2FE;
        border-radius: 9px;
    }

    /* Nút Thanh Toán */
    QPushButton#btnPay {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #0EA5E9, stop:1 #0284C7);
        border: none;
        border-radius: 12px;
        color: #ffffff;
        font-size: 15px;
        font-weight: bold;
    }
    QPushButton#btnPay:hover {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #38BDF8, stop:1 #0284C7);
    }
   </string>
